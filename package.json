{
  "name": "dev-agent",
  "version": "1.0.0",
  "description": "Dev Agent - 基于 Claude Code 架构的开源 AI 编程助手",
  "type": "module",
  "main": "dist/main.js",
  "bin": {
    "dev-agent": "dist/main.js"
  },
  "scripts": {
    "build": "bun run build:bundle",
    "build:bundle": "bun build src/entrypoints/cli.tsx --outdir dist --target node --format esm --sourcemap=external --external @ant/claude-for-chrome-mcp --external @anthropic-ai/bedrock-sdk --external @anthropic-ai/foundry-sdk --external @anthropic-ai/mcpb --external @anthropic-ai/sandbox-runtime --external @anthropic-ai/vertex-sdk --external @azure/identity --external color-diff-napi --external modifiers-napi --external sharp --external fflate --external turndown",
    "dev": "bun run src/entrypoints/cli.tsx",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@alcalzone/ansi-tokenize": "^0.1.3",
    "@anthropic-ai/sdk": "^0.39.0",
